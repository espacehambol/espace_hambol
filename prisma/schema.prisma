generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Site {
  id        String   @id @default(cuid())
  name      String   // Azaguié, Yopougon
  location  String?
  description String?
  rooms     Room[]
  services  Service[]
  staff     Staff[]
  inventory InventoryItem[]
  lostItems LostItem[]
  transactions Transaction[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  dishes    Dish[]
}

model RoomType {
  id          String   @id @default(cuid())
  name        String   // Standard, Suite, Luxe
  description String?
  price       Float
  capacity    Int
  rooms       Room[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Room {
  id          String   @id @default(cuid())
  number      String
  status      String   @default("AVAILABLE") // AVAILABLE, OCCUPIED, CLEANING, MAINTENANCE
  roomType    RoomType @relation(fields: [roomTypeId], references: [id])
  roomTypeId  String
  site        Site     @relation(fields: [siteId], references: [id])
  siteId      String
  reservations Reservation[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Reservation {
  id         String   @id @default(cuid())
  checkIn    DateTime
  checkOut   DateTime
  status     String   @default("PENDING") // PENDING, CONFIRMED, CANCELLED, COMPLETED
  checkInStatus String @default("NOT_STARTED") // NOT_STARTED, KYC_SUBMITTED, READY_FOR_KEY, CHECKED_IN
  totalPrice Float
  room       Room     @relation(fields: [roomId], references: [id])
  roomId     String
  client     User     @relation(fields: [clientId], references: [id])
  clientId   String
  kycData    KycData?
  paymentIntentId String?
  paymentStatus   String @default("UNPAID") // UNPAID, PARTIAL, PAID, FAILED
  transactions    Transaction[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model KycData {
  id             String      @id @default(cuid())
  idType         String      // Passport, CNI
  idNumber       String
  idExpiry       DateTime?
  idImage        String?     // URL to uploaded image
  reservation    Reservation @relation(fields: [reservationId], references: [id])
  reservationId  String      @unique
  createdAt      DateTime    @default(now())
}

model GuestPreferences {
  id             String   @id @default(cuid())
  pillowType     String?
  beverages      String?  // Liste de boissons favorites
  cleaningTime   String?  // Heure préférée
  dietaryNotes   String?
  user           User     @relation(fields: [userId], references: [id])
  userId         String   @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  password     String
  role         String   @default("CLIENT") // CLIENT, ADMIN, STAFF
  reservations Reservation[]
  staffProfile Staff?
  loyalty      LoyaltyProgram?
  preferences  GuestPreferences?
  transactions Transaction[]
  reviews      Review[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model LoyaltyProgram {
  id        String   @id @default(cuid())
  points    Int      @default(0)
  tier      String   @default("STANDARD") // STANDARD, SILVER, GOLD, PLATINUM
  user      User     @relation(fields: [userId], references: [id])
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Transaction {
  id          String   @id @default(cuid())
  amount      Float
  type        String   // INVOICE, PAYMENT, REFUND
  status      String   @default("PENDING") // PENDING, PAID, CANCELLED
  description String?
  category    String   @default("AUTRE") // HEBERGEMENT, RESTAURANT, BAR, SPA, LOISIRS, AUTRE
  user        User     @relation(fields: [userId], references: [id])
  userId      String
  reservation Reservation? @relation(fields: [reservationId], references: [id])
  reservationId String?
  site        Site?    @relation(fields: [siteId], references: [id])
  siteId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ConciergeRequest {
  id          String   @id @default(cuid())
  type        String   // ROOM_SERVICE, MAINTENANCE, TOWELS, etc.
  status      String   @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED
  description String?
  roomNumber  String
  site        String   // Azaguié, Yopougon
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String?
  category  String?  // Room, Food, Service
  status    String   @default("PENDING") // PENDING, APPROVED, REJECTED
  site      String   @default("Yopougon") // Yopougon, Azaguié
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Staff {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String   @unique
  site      Site     @relation(fields: [siteId], references: [id])
  siteId    String
  position  String   // Receptionist, Manager, etc.
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Service {
  id          String   @id @default(cuid())
  name        String   // Restaurant, Spa, Pool
  description String?
  price       Float?
  site        Site     @relation(fields: [siteId], references: [id])
  siteId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model InventoryItem {
  id          String   @id @default(cuid())
  name        String
  category    String   // Food, Beverage, Housekeeping, Linen
  quantity    Float
  unit        String   // kg, unit, bottle, etc.
  minThreshold Float   @default(5)
  site        Site     @relation(fields: [siteId], references: [id])
  siteId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Dish {
  id          String          @id @default(cuid())
  name        String
  category    String          // Signature, Terroir, Tradition, etc.
  description String?
  price       Float?
  image       String?         // Path to image
  site        Site            @relation(fields: [siteId], references: [id])
  siteId      String
  isActive    Boolean         @default(true)
  components  DishComponent[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model DishComponent {
  id       String  @id @default(cuid())
  name     String          // ex: "Riz", "Attiéké", "Poulet braisé"
  type     String          // PROTEIN, GARNISH, SAUCE, OPTION
  optional Boolean @default(false)
  dish     Dish    @relation(fields: [dishId], references: [id], onDelete: Cascade)
  dishId   String
}

model SystemSetting {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LostItem {
  id             String   @id @default(cuid())
  name           String
  description    String?
  photoUrl       String?
  roomNumber     String?
  status         String   @default("FOUND") // FOUND, CLAIMED, SHIPPED
  trackingNumber String?
  dateFound      DateTime @default(now())
  site           Site     @relation(fields: [siteId], references: [id])
  siteId         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
